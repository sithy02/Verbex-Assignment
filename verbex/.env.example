# Database — use postgresql+asyncpg:// (NOT postgresql://) to avoid asyncpg SSL errors
DATABASE_URL=postgresql+asyncpg://user:password@your-neon-host/dbname

# Auth
JWT_SECRET=your-super-secret-random-string-here-change-this

# LLM
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Inter-service URLs (Docker internal network)
AUTH_SERVICE_URL=http://auth-service:8081
AGENT_SERVICE_URL=http://agent-service:8082
CHAT_SERVICE_URL=http://chat-service:8083

# Frontend (browser-accessible)
NEXT_PUBLIC_AUTH_URL=http://localhost:8081
NEXT_PUBLIC_AGENT_URL=http://localhost:8082
NEXT_PUBLIC_CHAT_URL=http://localhost:8083
